<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.FileInfoMapper">
    
    <resultMap id="FileInfoResultMap" type="com.example.demo.entity.FileInfo">
        <id property="id" column="id"/>
        <result property="fileIdentifier" column="file_identifier"/>
        <result property="fileName" column="file_name"/>
        <result property="fileSize" column="file_size"/>
        <result property="fileType" column="file_type"/>
        <result property="filePath" column="file_path"/>
        <result property="md5" column="md5"/>
        <result property="status" column="status"/>
        <result property="totalChunks" column="total_chunks"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, file_identifier, file_name, file_size, file_type, file_path, md5, status, total_chunks, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.example.demo.entity.FileInfo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO file_info (file_identifier, file_name, file_size, file_type, file_path, md5, status, total_chunks, created_at, updated_at)
        VALUES (#{fileIdentifier}, #{fileName}, #{fileSize}, #{fileType}, #{filePath}, #{md5}, #{status}, #{totalChunks}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.example.demo.entity.FileInfo">
        UPDATE file_info
        <set>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="fileType != null">file_type = #{fileType},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="md5 != null">md5 = #{md5},</if>
            <if test="status != null">status = #{status},</if>
            <if test="totalChunks != null">total_chunks = #{totalChunks},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <select id="findById" resultMap="FileInfoResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM file_info
        WHERE id = #{id}
    </select>

    <select id="findByFileIdentifier" resultMap="FileInfoResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM file_info
        WHERE file_identifier = #{fileIdentifier}
    </select>

    <select id="findByMd5" resultMap="FileInfoResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM file_info
        WHERE md5 = #{md5}
    </select>

    <select id="findByStatus" resultMap="FileInfoResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM file_info
        WHERE status = #{status}
    </select>

    <delete id="deleteById">
        DELETE FROM file_info
        WHERE id = #{id}
    </delete>
</mapper>
