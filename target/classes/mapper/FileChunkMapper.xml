<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.FileChunkMapper">
    
    <resultMap id="FileChunkResultMap" type="com.example.demo.entity.FileChunk">
        <id property="id" column="id"/>
        <result property="fileIdentifier" column="file_identifier"/>
        <result property="chunkNumber" column="chunk_number"/>
        <result property="chunkSize" column="chunk_size"/>
        <result property="chunkPath" column="chunk_path"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, file_identifier, chunk_number, chunk_size, chunk_path, created_at
    </sql>

    <insert id="insert" parameterType="com.example.demo.entity.FileChunk" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO file_chunk (file_identifier, chunk_number, chunk_size, chunk_path, created_at)
        VALUES (#{fileIdentifier}, #{chunkNumber}, #{chunkSize}, #{chunkPath}, NOW())
    </insert>

    <select id="findByFileIdentifierAndChunkNumber" resultMap="FileChunkResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM file_chunk
        WHERE file_identifier = #{fileIdentifier} AND chunk_number = #{chunkNumber}
    </select>

    <select id="findByFileIdentifier" resultMap="FileChunkResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM file_chunk
        WHERE file_identifier = #{fileIdentifier}
        ORDER BY chunk_number ASC
    </select>

    <select id="countByFileIdentifier" resultType="int">
        SELECT COUNT(*)
        FROM file_chunk
        WHERE file_identifier = #{fileIdentifier}
    </select>

    <delete id="deleteByFileIdentifier">
        DELETE FROM file_chunk
        WHERE file_identifier = #{fileIdentifier}
    </delete>
</mapper>
